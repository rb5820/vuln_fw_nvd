<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Form View -->
    <record id="view_vuln_fw_nvd_api_client_form" model="ir.ui.view">
        <field name="name">vuln.fw.nvd.api.client.form</field>
        <field name="model">vuln.fw.nvd.api.client</field>
        <field name="arch" type="xml">
            <form string="API Client Configuration">
                <header>
                    <button name="action_regenerate_token" 
                            string="🔄 Regenerate Token" 
                            type="object"
                            class="btn-warning"
                            confirm="This will invalidate the current token. Are you sure?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Inactive" bg_color="bg-danger" 
                            invisible="active"/>
                    <widget name="web_ribbon" title="Token Expired" bg_color="bg-warning" 
                            invisible="not token_expires or token_expires &gt; current_date"/>
                    
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Production Lansweeper Server"/></h1>
                    </div>
                    
                    <group>
                        <group name="basic_info">
                            <field name="client_type" widget="radio"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="description" placeholder="Purpose and details about this API client"/>
                        </group>
                        <group name="statistics">
                            <label for="total_requests" string="Request Statistics"/>
                            <div>
                                <div><strong><field name="total_requests" class="text-primary"/> Total</strong></div>
                                <div><field name="successful_requests" class="text-success"/> Successful</div>
                                <div><field name="failed_requests" class="text-danger"/> Failed</div>
                            </div>
                            <field name="last_request_date"/>
                            <field name="last_request_ip"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="🔑 Authentication" name="authentication">
                            <group>
                                <group>
                                    <field name="api_token" password="True" 
                                           widget="CopyClipboardChar"
                                           help="Click to copy. Keep this secure!"/>
                                    <field name="token_expires"/>
                                </group>
                            </group>
                            
                            <div class="alert alert-warning mt-3" role="alert">
                                <strong>⚠️ Security Notice:</strong><br/>
                                • Store this token securely on the client side<br/>
                                • Never commit tokens to version control<br/>
                                • Rotate tokens regularly for production systems<br/>
                                • Use IP whitelisting in production environments
                            </div>
                        </page>
                        
                        <page string="🔒 Access Control" name="access_control">
                            <group>
                                <group string="IP Whitelist">
                                    <field name="enforce_ip_whitelist"/>
                                    <field name="allowed_ip_addresses" 
                                           invisible="not enforce_ip_whitelist"
                                           placeholder="192.168.1.100, 10.0.0.0/24"/>
                                </group>
                                
                                <group string="Endpoint Permissions">
                                    <field name="allowed_endpoints" widget="radio"/>
                                    <field name="can_subscribe_cpe" 
                                           invisible="allowed_endpoints != 'custom'"
                                           string="✓ Subscribe CPE Endpoint"/>
                                    <field name="can_sync_cpe" 
                                           invisible="allowed_endpoints != 'custom'"
                                           string="✓ Sync CPE Endpoint"/>
                                </group>
                            </group>
                            
                            <group string="Rate Limiting">
                                <group>
                                    <field name="rate_limit_enabled"/>
                                    <field name="rate_limit_requests" 
                                           invisible="not rate_limit_enabled"/>
                                    <field name="rate_limit_period" 
                                           invisible="not rate_limit_enabled"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="📝 Notes" name="notes">
                            <field name="notes" placeholder="Internal notes about this API client..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    
    <!-- List View -->
    <record id="view_vuln_fw_nvd_api_client_list" model="ir.ui.view">
        <field name="name">vuln.fw.nvd.api.client.list</field>
        <field name="model">vuln.fw.nvd.api.client</field>
        <field name="arch" type="xml">
            <list string="API Clients" sample="1">
                <field name="name"/>
                <field name="client_type"/>
                <field name="total_requests" string="Requests"/>
                <field name="successful_requests" string="Success"/>
                <field name="failed_requests" string="Failed"/>
                <field name="last_request_date"/>
                <field name="token_expires" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <!-- Search View -->
    <record id="view_vuln_fw_nvd_api_client_search" model="ir.ui.view">
        <field name="name">vuln.fw.nvd.api.client.search</field>
        <field name="model">vuln.fw.nvd.api.client</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_type"/>
                <field name="api_token"/>
                
                <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="filter_inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Token Expired" name="filter_expired" 
                        domain="[('token_expires', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Lansweeper Clients" name="filter_lansweeper" 
                        domain="[('client_type', '=', 'lansweeper')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Client Type" name="group_type" context="{'group_by': 'client_type'}"/>
                    <filter string="Active Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Action -->
    <record id="action_vuln_fw_nvd_api_client" model="ir.actions.act_window">
        <field name="name">API Clients</field>
        <field name="res_model">vuln.fw.nvd.api.client</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first API Client!
            </p>
            <p>
                API Clients are external systems that can access your vulnerability data via REST API.<br/>
                This is separate from webhook receivers and designed for bidirectional communication.
            </p>
        </field>
    </record>
    
    <!-- Menu Items -->
    <menuitem id="menu_vuln_fw_nvd_api_clients"
              name="🔌 API Clients"
              parent="menu_nvd_config"
              action="action_vuln_fw_nvd_api_client"
              sequence="30"/>
    
</odoo>
